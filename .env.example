# Azure DevOps Configuration
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/your-organization
AZURE_DEVOPS_PAT=your-personal-access-token

# GitHub CLI — necessário para acessar repos privados da org wiipobr
# Aponta para a pasta onde o gh armazena as credenciais (gh auth login)
# Descubra o caminho correto rodando: gh auth status e verificando onde hosts.yml está
GH_CONFIG_DIR=/Users/your-user/.gh-config
